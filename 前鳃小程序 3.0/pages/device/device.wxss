page {
  background-color: #f5f7fa;
  padding: 30rpx;
  margin: 0;
}
.container {
  width: 92%;
  box-sizing: border-box;
}
.card {
  background: #ffffff;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}
.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}
.card-icon {
  font-size: 44rpx;
  margin-right: 16rpx;
}
.title {
  font-size: 38rpx;
  font-weight: 600;
  color: #1a1a1a;
}

/* 输入框区域 */
.input-wrap {
  margin-bottom: 24rpx;
}
.device-input {
  width: 100%;
  height: 90rpx;
  border: 1rpx solid #e6e8eb;
  border-radius: 16rpx;
  padding: 0 30rpx;
  font-size: 30rpx;
  background: #fafbfc;
  box-sizing: border-box;
}
.device-input:focus {
  border-color: #409EFF;
  background: #fff;
}

/* 按钮组 */
.btn-group {
  display: flex;
  gap: 20rpx;
  margin-bottom: 20rpx;
}
.btn {
  flex: 1;
  height: 84rpx;
  border-radius: 42rpx;
  font-size: 30rpx;
  border: none;
}
.bind-btn {
  background: linear-gradient(135deg, #409EFF, #2078d8);
  color: #fff;
  box-shadow: 0 6rpx 16rpx rgba(64, 158, 255, 0.25);
}
.clear-btn {
  background: #f0f2f5;
  color: #666;
}
.tip-text {
  font-size: 26rpx;
  color: #909399;
  line-height: 1.6;
}

/* 设备信息行 */
.info-row {
  display: flex;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}
.info-row:last-child {
  border-bottom: none;
}
.label {
  font-size: 30rpx;
  color: #606266;
}
.value {
  font-size: 30rpx;
  color: #1a1a1a;
  font-weight: 500;
}
.status.online {
  color: #00b42a;
  font-weight: 500;
}

/* 解绑按钮 */
.unbind-wrap {
  margin-top: 40rpx;
  padding-top: 30rpx;
  border-top: 1rpx dashed #eee;
}
.unbind-btn {
  width: 100%;
  height: 84rpx;
  border-radius: 42rpx;
  background: #fff2f2;
  color: #ff4d4f;
  font-size: 30rpx;
  border: 1rpx solid #ffcccc;
}

/* 空占位卡片 */
.empty-card {
  text-align: center;
  padding: 60rpx 30rpx;
}
.empty-icon {
  font-size: 100rpx;
  color: #dcdfe6;
  margin-bottom: 20rpx;
}
.empty-text {
  font-size: 34rpx;
  color: #606266;
  display: block;
  margin-bottom: 12rpx;
}
.empty-desc {
  font-size: 26rpx;
  color: #909399;
  line-height: 1.7;
}