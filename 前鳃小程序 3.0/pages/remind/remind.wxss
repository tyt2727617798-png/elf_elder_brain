page {
  background: #f5f7fa;
  font-size: 30rpx;
}
.container {
  width: 100%;
  box-sizing: border-box;
}
.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
}
.title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}
.remind-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #eee;
}
.input {
  width: 100%;
  border: 1rpx solid #eee;
  /* 加大上下内边距，文字不会贴边截断 */
  padding: 24rpx 20rpx;
  border-radius: 10rpx;
  margin: 20rpx 0;
  box-sizing: border-box;
  font-size: 30rpx;
  line-height: 1.5;
  min-height: 100rpx;
}
.time-picker {
  width: 100%;
  border: 1rpx solid #eee;
  border-radius: 10rpx;
  margin-bottom: 20rpx;
}
.time-text {
  padding: 18rpx;
  color: #666;
}
.btn {
  width: 100%;
  height: 80rpx;
  border-radius: 50rpx;
}
/* 滚动列表容器 */
.list-scroll {
  max-height: 600rpx;
}
/* 左滑删除核心样式 */
.slide-area {
  position: relative;
  width: 100%;
  height: 90rpx;
  overflow: hidden;
  border-bottom: 1rpx solid #eee;
}
.slide-content {
  width: 100%;
  height: 100%;
  background: #fff;
  display: flex;
  align-items: center;
  padding: 0 20rpx;
}
.item-text {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
}
.slide-delete {
  position: absolute;
  right: 0;
  top: 0;
  width: 130rpx;
  height: 90%;
  background: #ff3b30;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
}